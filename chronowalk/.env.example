# Required — Mapbox public token (also set in Netlify Environment variables)
VITE_MAPBOX_TOKEN=your_mapbox_public_token_here

# Local dev: teleport GPS to Rome for testing
# On Netlify: add this in Site settings → Environment variables, then redeploy.
# Quick test without redeploy: open your site with ?debugGeo=true
VITE_DEBUG_GEO=true

# Creator studio — AI prompt generator (?assetStudio=true&waypoint=colosseum)
# VITE_ASSET_STUDIO=true

# Supabase — waypoint data including audio URLs
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional — CDN base URL for assets (e.g. Cloudflare R2 / custom domain)
# VITE_CDN_BASE_URL=https://cdn.example.com

# Optional — post-tour review prompt (App Store / Play Store listing)
# VITE_REVIEW_URL=https://apps.apple.com/app/id123456789?action=write-review

# Optional — private feedback for unhappy users (mailto or form URL)
# VITE_FEEDBACK_URL=mailto:feedback@example.com?subject=ChronoWalk%20feedback
